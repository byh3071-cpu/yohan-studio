# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# lazyweb (quick-references, screenshots, local cache)
.lazyweb/

# playwright MCP cache
.playwright-mcp/

# local dev server logs
/logs/

# editor / agent local config
.claude/
.vscode/

# playwright / qa artifacts (binary heavy, regenerated locally)
playwright-report/
test-results/
qa-artifacts/
public/qa-artifacts/

# scratch / verification dumps
tmp-*.html
vhk-verify-*.png
scripts/.verify/
/.tmp-cover.html
/.tmp-gif
/.tmp-emoji/
# 아이콘 탐색 작업분 (후보 수집·비교판·생성 원본) — 확정본만 src/data·public에 커밋
/.tmp-icons/
/.tmp-icons-*.json
# 브라우저 세션 덤프·검증 스크린샷 (루트) — 스크래치패드로 저장하는 게 정석이나 루트 유출 방어
/update-mode-*.md
/naver-*.jpeg
/naver-*.png
/mock-*.jpeg
/chk-*.png
/emoji-*.png
/robot-*.png
/gen*-compare.png
/gen-compare.png
/vec-check*.png
/ai-brainstorm.png
/w-*.png
/web-*.png
# 검증용 임시 글 (published:true로 두고 로컬 확인 후 버린다)
src/content/blog/tmp-*.mdx
docs/content/naver/_tmp-*.md
# 이모지 시안·생성 드래프트 (실험분 — 최종은 <name>-solid.png만 커밋)
/public/images/emoji/_drafts/

# serena MCP cache
.serena/

# 네이버 발행: .html은 .md에서 naver-to-html.mjs로 재생성 (소스 .md만 커밋)
docs/content/naver/*.html
