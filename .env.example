# Copy to .env.local and fill in values. Never commit .env.local.
# git worktree 사용 시 각 worktree에 .env.local을 따로 복사해야 함.

# --- Site (Phase 1+) ---
# Canonical site URL (no trailing slash). Production: https://yohanstudio.co
NEXT_PUBLIC_SITE_URL=https://yohanstudio.co

# --- SEO / Analytics (Phase 2, optional) ---
NEXT_PUBLIC_GSC_VERIFICATION=
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
NEXT_PUBLIC_GA_ID=

# --- Contact / Services (Phase 2, optional) ---
# External form URL for /services CTA (?service= prefill)
NEXT_PUBLIC_CONTACT_FORM_URL=

# --- AI Chatbot (Gemini) ---
GOOGLE_GENERATIVE_AI_API_KEY=

# --- AI Chatbot TTS (Google Cloud Text-to-Speech REST) ---
GOOGLE_TTS_API_KEY=

# --- Supabase (Phase 3, Focus Feed shared project) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Phase 3) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Contact form email (Phase 3, /api/contact via Resend) ---
RESEND_API_KEY=
# Optional — defaults: onboarding@resend.dev / byh3071@gmail.com
RESEND_FROM_ADDRESS=
CONTACT_NOTIFY_TO=
