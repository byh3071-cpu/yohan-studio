# Copy to .env.local and fill in values. Never commit .env.local.
# git worktree 사용 시 각 worktree에 .env.local을 따로 복사해야 함.

# --- Site (Phase 1+) ---
# Used by: src/lib/siteUrl.ts, metadata canonical/OG URLs
# Canonical site URL (no trailing slash). Production: https://yohanstudio.co
NEXT_PUBLIC_SITE_URL=https://yohanstudio.co

# --- SEO / Analytics (Phase 2, optional) ---
# Used by: src/app/layout.tsx metadata.verification.google
NEXT_PUBLIC_GSC_VERIFICATION=
# Used by: src/app/layout.tsx metadata.verification.other (naver)
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=
# Used by: src/app/layout.tsx @next/third-parties GoogleAnalytics
NEXT_PUBLIC_GA_ID=

# --- Contact / Services (Phase 2, optional) ---
# Used by: src/app/services/page.tsx external CTA (?service= prefill)
NEXT_PUBLIC_CONTACT_FORM_URL=

# --- AI Chatbot (Gemini) ---
# Used by: src/app/api/chat/route.ts — missing → 503 Korean error
GOOGLE_GENERATIVE_AI_API_KEY=

# --- AI Chatbot TTS (Google Cloud Text-to-Speech REST) ---
# Used by: src/lib/tts.ts — missing → TTS disabled
GOOGLE_TTS_API_KEY=

# --- Supabase (Phase 3, Focus Feed shared project) ---
# Used by: src/lib/supabase.ts (browser), store pages
NEXT_PUBLIC_SUPABASE_URL=
# Used by: src/lib/supabase.ts (browser anon client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Used by: src/lib/supabase-server.ts, scripts/seed.ts — server only, never NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (Phase 3, server-side Checkout Session) ---
# Used by: src/lib/stripe.ts
STRIPE_SECRET_KEY=
# Used by: src/app/api/webhook/route.ts
STRIPE_WEBHOOK_SECRET=
# Note: NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY is NOT used — Checkout is server-created.

# --- Contact form email (Phase 3, /api/contact via Resend) ---
# Used by: src/lib/resend.ts
RESEND_API_KEY=
# Used by: src/lib/resend.ts — default: onboarding@resend.dev
RESEND_FROM_ADDRESS=
# Used by: src/lib/resend.ts — default: byh3071@gmail.com
CONTACT_NOTIFY_TO=
